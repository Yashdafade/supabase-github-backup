# .env.example — copy this to .env and fill in your values
# Never commit your actual .env file

# Your Supabase project URL
# Found at: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase service role key (NOT the anon key)
# Found at: Supabase Dashboard → Settings → API → service_role (secret)
# ⚠️ Keep this secret — it bypasses Row Level Security
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# A strong secret passphrase used to encrypt/decrypt backups locally and in CI
# ⚠️ Keep this secret safe. If lost, you cannot recover your backups.
BACKUP_ENCRYPTION_KEY=your-custom-secure-passphrase-here

# Your GitHub Personal Access Token (PAT)
# Required for the GitHub Actions workflow to push backups back to your repository
BACKUP_GITHUB_TOKEN=your-github-personal-access-token-here


